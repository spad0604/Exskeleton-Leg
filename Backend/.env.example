BIND_ADDRESS=0.0.0.0:8080
DATABASE_URL=postgres://postgres:postgres@localhost:5432/exoskeleton_leg
DATABASE_MAX_CONNECTIONS=10
JWT_SECRET=replace-with-at-least-32-random-bytes
